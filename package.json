{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "web-archive",
  "title": "Web Archive",
  "description": "Search snapshots from Web Archive",
  "icon": "extension-icon.png",
  "author": "tofrankie",
  "license": "MIT",
  "scripts": {
    "dev": "ray develop",
    "build": "ray build",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "dependencies": {
    "@raycast/api": "^1.104.3",
    "@raycast/utils": "^2.2.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "platforms": [
    "macOS",
    "Windows"
  ],
  "categories": [
    "Developer Tools"
  ],
  "commands": [
    {
      "name": "search-web-archive",
      "title": "Search Web Archive",
      "description": "Search snapshots from web.archive.org by URL",
      "mode": "view"
    }
  ]
}
